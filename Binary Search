"""二分查找-Leetcode 34"""
from typing import List
def lowerbound(nums,target):
    left = -1
    right = len(nums)
    while left + 1 < right:
        mid = (left + right) // 2
        if nums[mid] < target:
            left = mid
        else:
            right = mid
    return right

class Solution:
    def searchRange(self, nums: List[int], target: int) -> List[int]:
        start = lowerbound(nums,target)
        if start == len(nums) or nums[start] != target:
            return [-1,-1]
        else:
            end = lowerbound(nums,target + 1 ) - 1 
            return [start,end]
